# Env-var contract — see docs/phases/phase-4-ui.md for full details.
#
# Vite exposes only variables prefixed VITE_* to the client bundle.

# Backend routing service base URL (no trailing slash).
VITE_ROUTING_API_URL=http://localhost:58000

# Self-hosted Nominatim base URL (no trailing slash). The browser calls this
# directly — never proxied through the routing service (design D6).
VITE_NOMINATIM_URL=http://localhost:58080

# Photon geocoder base URL for address autocomplete (no trailing slash). The
# browser calls this directly (design D5/D6). Dev defaults to the public demo;
# for self-hosting point at http://localhost:52322 (infra `photon` profile).
VITE_PHOTON_URL=https://photon.komoot.io

# Basemap tile URL. Public OSM tiles in dev; swap to TileServer GL in Phase 5.
VITE_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
