# Routing database
POSTGRES_PASSWORD=changeme-in-dev-only
POSTGRES_PRIMARY_PORT=55432
POSTGRES_REPLICA_PORT=55433

# Redis
REDIS_PORT=56379

# Nominatim
NOMINATIM_PASSWORD=changeme-in-dev-only
NOMINATIM_PORT=58080
NOMINATIM_THREADS=4

# Photon geocoder (address autocomplete, design D5/D6).
# UI_PHOTON_URL is baked into the UI build (browser-direct). Dev defaults to the
# public demo; for self-hosting enable the `photon` profile and point this at
# http://localhost:${PHOTON_PORT}.
UI_PHOTON_URL=https://photon.komoot.io
PHOTON_PORT=52322
# Country extract for the self-hosted index (e.g. us, de); empty = full planet.
PHOTON_COUNTRY_CODE=

# Logging (json | text)
LOG_FORMAT=text
LOG_LEVEL=INFO
