<?xml version="1.0" encoding="UTF-8"?>
<!--
  osm2pgrouting tag-class mapping for the closest-facility routing service.

  This is a trimmed copy of the upstream sample mapconfig.xml, keeping only
  the OSM tags we actually care about for vehicle routing:
    * tag_name=highway with the standard class set
    * tag_name=oneway   so directionality is honoured
    * tag_name=maxspeed so cost_time can override the highway-class default
      (Phase 2 task 2.2)

  We intentionally OMIT bicycle / pedestrian / railway / waterway classes —
  the v1 product surface is vehicle-only. Adding them is a future change and
  costs nothing here.

  Reference: https://github.com/pgRouting/osm2pgrouting (mapconfig.xml)
-->
<configuration>
  <tag_name name="highway" id="1">
    <tag_value name="motorway"       id="101" priority="1.0" maxspeed="110" />
    <tag_value name="motorway_link"  id="102" priority="1.0" maxspeed="90"  />
    <tag_value name="trunk"          id="103" priority="1.0" maxspeed="100" />
    <tag_value name="trunk_link"     id="104" priority="1.0" maxspeed="80"  />
    <tag_value name="primary"        id="105" priority="1.5" maxspeed="80"  />
    <tag_value name="primary_link"   id="106" priority="1.5" maxspeed="60"  />
    <tag_value name="secondary"      id="107" priority="2.0" maxspeed="60"  />
    <tag_value name="secondary_link" id="108" priority="2.0" maxspeed="50"  />
    <tag_value name="tertiary"       id="109" priority="2.5" maxspeed="50"  />
    <tag_value name="tertiary_link"  id="110" priority="2.5" maxspeed="40"  />
    <tag_value name="residential"    id="111" priority="3.0" maxspeed="30"  />
    <tag_value name="living_street"  id="112" priority="3.0" maxspeed="20"  />
    <tag_value name="unclassified"   id="113" priority="3.0" maxspeed="30"  />
    <tag_value name="service"        id="114" priority="3.5" maxspeed="20"  />
  </tag_name>
</configuration>
